# Shared runtime configuration
FIREBASE_DB_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app
FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/firebase-service-account.json
PUBLIC_CLAIM_BASE_URL=https://claim.example.com
LAPTOP_DASHBOARD_BASE_URL=http://your-laptop-tailnet-name:5000
PI_NODE_NAME=pi-front-counter

# Hosted public-claim Firebase web config
FIREBASE_WEB_API_KEY=replace-me
FIREBASE_WEB_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_WEB_PROJECT_ID=your-project
FIREBASE_WEB_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_WEB_MESSAGING_SENDER_ID=replace-me
FIREBASE_WEB_APP_ID=replace-me
FIREBASE_WEB_MEASUREMENT_ID=replace-me
